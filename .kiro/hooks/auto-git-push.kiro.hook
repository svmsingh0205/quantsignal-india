{
  "enabled": true,
  "name": "Auto Push to GitHub",
  "description": "Automatically commits and pushes all changes to GitHub after any file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.py",
      "*.toml",
      "*.txt",
      "*.md"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "give link after every step\n"
  },
  "workspaceFolderName": "fi",
  "shortName": "auto-git-push"
}